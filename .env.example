NEXT_PUBLIC_SITE_URL=https://my-whois.com
NEXT_PUBLIC_UMAMI_WEBSITE_ID=https://analytics.flndrn.com 
NEXT_PUBLIC_UMAMI_HOST=

# Google AdSense — only 2 ad slots are wired into the site:
#   MID    → placed mid-content on /, /[domain], /compare/[slug]
#   FOOTER → bottom of every page-with-side-ads layout
# Both should be created as "Display ads", "Horizontal", responsive.
# Client ID has a default of ca-pub-3928224800312187 baked into the code,
# so the loader script ships even without this env set.
NEXT_PUBLIC_ADSENSE_CLIENT_ID=
NEXT_PUBLIC_ADSENSE_SLOT_MID=
NEXT_PUBLIC_ADSENSE_SLOT_FOOTER=

# Operations
ADMIN_EMAIL=admin@flndrn.com
HARO_EMAIL=haro@flndrn.com

# IndexNow — Bing/Yandex/DuckDuckGo push
INDEXNOW_KEY=

# Registrar referral codes (NEXT_PUBLIC_ so they render into client-side links)
NEXT_PUBLIC_HOSTINGER_REF=
NEXT_PUBLIC_PORKBUN_REF=
NEXT_PUBLIC_NAMECHEAP_AFF=
NEXT_PUBLIC_GODADDY_AFF=
NEXT_PUBLIC_DYNADOT_REF=
NEXT_PUBLIC_NAMESILO_RID=
NEXT_PUBLIC_IONOS_AFF=
NEXT_PUBLIC_SPACESHIP_REF=
NEXT_PUBLIC_NAMECOM_AFF=
NEXT_PUBLIC_HOVER_REF=
NEXT_PUBLIC_DREAMHOST_REF=
NEXT_PUBLIC_HOSTGATOR_AFF=

# Resend — only when contact form added
RESEND_API_KEY=
RESEND_FROM=noreply@flndrn.com
RESEND_REPLY_TO=admin@flndrn.com
